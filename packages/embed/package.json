{
  "name": "@labirthermal/webcomponents",
  "version": "1.3.4",
  "description": "Embedded display of thermograms",
  "main": "dist/embed.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/moichim/labir"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "eslint": "eslint src",
    "test": "vitest src",
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:lib",
    "build:cjs": "vite build --config vite.config.ts",
    "build:esm": "vite build --config vite.config.esm.ts",
    "build:lib": "tsdown",
    "serve": "serve dist/",
    "lint": "eslint src"
  },
  "author": "Jan Jáchim <jachim@ntc.zcu.cz>",
  "license": "ISC",
  "exports": {
    ".": "./dist/embed.js",
    "./lib/*": "./lib/*",
    "./api": "./lib/index.js"
  },
  "types": "lib/index.d.ts",
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@google-web-components/google-chart": "^5.1.0",
    "@labirthermal/core": "workspace:*",
    "@labirthermal/server": "workspace:*",
    "@labirthermal/server-simple": "workspace:*",
    "@lit/context": "^1.1.6",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "lit": "^3.3.2",
    "lit-code": "^0.1.12",
    "lit-i18n": "^4.1.0",
    "mediabunny": "^1.35.1",
    "npm": "^11.11.0",
    "public-ip": "^8.0.0",
    "toolcool-range-slider": "^4.0.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "rollup-plugin-summary": "^3.0.1",
    "serve": "^14.2.5",
    "tsc": "^2.0.4",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-html-minifier": "^1.0.5",
    "vite-plugin-static-copy": "^3.2.0"
  }
}
